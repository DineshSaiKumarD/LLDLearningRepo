package ParkingLot;

import ParkingLot.enums.VehicleType;
import ParkingLot.models.Vehicle;
import ParkingLot.service.ParkingLotService;
import ParkingLot.service.ParkingSpot;

import java.util.Arrays;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class ParkingLotDriver {

    public static void main(String[] args) {
        //create parking spots
        ParkingSpot spot1 = new ParkingSpot("1", "CAR");
        ParkingSpot spot2 = new ParkingSpot("2", "BIKE");
        ParkingSpot spot3 = new ParkingSpot("3", "CAR");
        ParkingSpot spot4 = new ParkingSpot("4", "TRUCK");
        ParkingSpot spot5 = new ParkingSpot("5", "CAR");
        ParkingSpot spot6 = new ParkingSpot("6", "BIKE");
        ParkingSpot spot7 = new ParkingSpot("7", "CAR");
        ParkingSpot spot8 = new ParkingSpot("8", "TRUCK");
        ParkingSpot spot9 = new ParkingSpot("9", "CAR");
        ParkingSpot spot10 = new ParkingSpot("10", "BIKE");


        Map<VehicleType, List<ParkingSpot>> parkingSpotsMap = new HashMap<>();
        parkingSpotsMap.put(VehicleType.CAR, Arrays.asList(spot1, spot3, spot5, spot7, spot9));
        parkingSpotsMap.put(VehicleType.BIKE, Arrays.asList(spot2, spot6, spot10));
        parkingSpotsMap.put(VehicleType.TRUCK, Arrays.asList(spot4, spot8));

        //create parking lot
        ParkingLotService parkingLotService = new ParkingLotService(parkingSpotsMap);


        //create vehicle
        Vehicle vehicle1 = new Vehicle("V1", VehicleType.CAR);
        Vehicle vehicle2 = new Vehicle("V2", VehicleType.BIKE);
        Vehicle vehicle3 = new Vehicle("V3", VehicleType.CAR);
        Vehicle vehicle4 = new Vehicle("V4", VehicleType.TRUCK);
        Vehicle vehicle5 = new Vehicle("V5", VehicleType.CAR);
        Vehicle vehicle6 = new Vehicle("V6", VehicleType.BIKE);
        Vehicle vehicle7 = new Vehicle("V7", VehicleType.CAR);
        Vehicle vehicle8 = new Vehicle("V8", VehicleType.TRUCK);
        Vehicle vehicle9 = new Vehicle("V9", VehicleType.CAR);
        Vehicle vehicle10 = new Vehicle("V10", VehicleType.BIKE);


        //assign vehicle to spot
        if (parkingLotService.isSpotAvailable(vehicle1.getType())) {
            ParkingSpot availableSpot = parkingLotService.findAvailableSpot(vehicle1.getType());

            if (availableSpot != null) {
                parkingLotService.assignSpotToVehicle(availableSpot, vehicle1);
                System.out.println("Parked " + vehicle1.getId() + " at spot " + availableSpot.getSpotId());
                parkingLotService.generateTicket(  vehicle1,availableSpot);
            } else {
                System.out.println("No available spot for " + vehicle1.getId());
            }



        }
    }
}